{
  "name": "codepulse",
  "publisher": "shashank",
  "displayName": "CodePulse",
  "description": "Real-time developer presence platform.",
  "version": "1.0.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "CodePulse",
      "properties": {
        "codepulse.apiKey": {
          "type": "string",
          "default": "",
          "description": "Your CodePulse API Key (starting with cp_...)"
        },
        "codepulse.serverUrl": {
          "type": "string",
          "default": "ws://localhost:3001",
          "description": "CodePulse WebSocket Server URL"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./"
  },
  "dependencies": {
    "@codepulse/shared": "workspace:*",
    "ws": "^8.16.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "18.x",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.3.3"
  }
}
